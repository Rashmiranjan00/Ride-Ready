{
  "expo": {
    "name": "RideReady",
    "slug": "ride-ready",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rideready",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RideReady uses your location to track distance while riding.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RideReady uses your location to track distance while riding."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#131313",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#131313",
          "dark": {
            "backgroundColor": "#131313"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RideReady uses your location to track distance while riding.",
          "locationWhenInUsePermission": "RideReady uses your location to track distance while riding."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d92ae059-4cd4-44e2-9734-7651952733ee"
      }
    },
    "owner": "fraeloth-dev"
  }

}
